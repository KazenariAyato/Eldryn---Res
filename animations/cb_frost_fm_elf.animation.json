{
  "format_version": "1.8.0",
  "animations": {
    "animation.cb_frost_fm_elf.look_at_target": {
      "loop": true,
      "bones": {
        "Head": {
          "relative_to": {
            "rotation": "entity"
          },
          "rotation": [
            "query.target_x_rotation - this",
            "query.target_y_rotation - this",
            0
          ]
        }
      }
    },
    "animation.cb_frost_fm_elf.baby_transform": {
      "loop": true,
      "bones": {
        "Head": {
          "scale": [
            1.5,
            1.5,
            1.5
          ]
        }
      }
    },
    "animation.cb_frost_fm_elf.general": {
      "loop": true,
      "bones": {
        "arms": {
          "rotation": [
            "-42.97 - this",
            0,
            0
          ],
          "position": [
            0,
            -1,
            -1
          ]
        }
      }
    },
    "animation.villager.general.v1.0": {
      "loop": true,
      "bones": {
        "arms": {
          "rotation": [
            "-42.97 - this",
            0,
            0
          ],
          "position": [
            0,
            "-3.0 - this",
            "-1.0 - this"
          ]
        }
      }
    },
    "animation.villager.get_in_bed": {
      "loop": true,
      "bones": {
        "Body": {
          "rotation": [
            -90,
            0,
            0
          ],
          "position": [
            0,
            1,
            -15
          ]
        }
      }
    },
    "animation.cb_frost_fm_elf.move": {
      "loop": true,
      "anim_time_update": "query.modified_distance_moved",
      "bones": {
        "leg0": {
          "rotation": [
            "(math.cos(query.anim_time * 38.17) * 40.0) - this",
            "-this",
            0
          ]
        },
        "leg1": {
          "rotation": [
            "(math.cos(query.anim_time * 38.17 + 180) * 40.0) - this",
            "-this",
            0
          ]
        }
      }
    },
    "animation.villager.raise_arms": {
      "loop": true,
      "bones": {
        "arms": {
          "rotation": [
            "variable.raise_arms * -15.0",
            0,
            0
          ]
        }
      }
    }
  }
}