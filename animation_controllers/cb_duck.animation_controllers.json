{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.cb_duck.general": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": ["idle"],
          "transitions": [
            { "swim": "query.is_in_water || query.is_swimming" },
            { "walk": "query.modified_move_speed > 0.01" }
          ]
        },

        "walk": {
          "animations": ["walk"],
          "transitions": [
            { "swim": "query.is_in_water || query.is_swimming" },
            { "run": "query.modified_move_speed > 0.15" },
            { "idle": "query.modified_move_speed <= 0.01" }
          ]
        },

        "run": {
          "animations": ["run"],
          "transitions": [
            { "swim": "query.is_in_water || query.is_swimming" },
            { "walk": "query.modified_move_speed <= 0.15" },
            { "idle": "query.modified_move_speed <= 0.01" }
          ]
        },

        "swim": {
          "animations": ["swim"],
          "transitions": [
            { "idle": "!query.is_in_water && !query.is_swimming" }
          ]
        }
      }
    }
  }
}