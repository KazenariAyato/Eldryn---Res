{
  "format_version": "1.17.0",
  "animation_controllers": {
    "controller.animation.cb_dark_elf.main": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": ["idle"],
          "transitions": [
            { "walk": "query.modified_move_speed > 0.1" },
            { "swim": "query.is_in_water" }
          ]
        },
        "walk": {
          "animations": ["walk"],
          "transitions": [
            { "swim": "query.is_in_water" },
            { "run": "query.modified_move_speed > 0.5" },
            { "idle": "query.modified_move_speed <= 0.1" }
          ]
        },
        "run": {
          "animations": ["run"],
          "transitions": [
            { "swim": "query.is_in_water" },
            { "walk": "query.modified_move_speed <= 0.5" }
          ]
        },
        "swim": {
          "animations": ["swim"],
          "transitions": [
            { "idle": "!query.is_in_water" }
          ]
        }
      }
    }
  }
}