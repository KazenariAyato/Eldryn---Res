{
  "format_version": "1.19.0",
  "animation_controllers": {
    "controller.animation.cb_kitsune_demihumanform.move": {
      "states": {
        "idle": {
          "animations": [
            "look_at",
            "idle",
            {
              "move": "query.modified_move_speed"
            }
          ],
          "transitions": [
            {
              "attack": "query.has_target && variable.attack_time >= 0.1"
            },
            {
              "swim": "query.is_in_water"
            }
          ],
          "blend_transition": 0.1
        },
        "attack": {
          "animations": [
            "look_at",
            "attack",
            {
              "move": "query.modified_move_speed >= 0.7 && !query.is_in_water"
            },
            {
              "swim": "query.is_in_water && query.modified_move_speed >= 0.0"
            }
          ],
          "transitions": [
            {
              "idle": "!query.has_target && variable.attack_time <= 0.1"
            }
          ],
          "blend_transition": 2
        },
        "swim": {
          "animations": [
            "swim"
          ],
          "transitions": [
            {
              "idle": "!query.is_in_water"
            },
            {
              "attack": "query.has_target && variable.attack_time >= 0.1"
            }
          ],
          "blend_transition": 0.2
        }
      }
    }
  }
}