{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.cb_butterfly": {
      "initial_state": "flying",

      "states": {
        "flying": {
          "animations": [
            "fly"
          ],
          "transitions": [
            {
              "grounded": "query.is_on_ground"
            }
          ]
        },

        "grounded": {
          "animations": [
            "idle"
          ],
          "transitions": [
            {
              "flying": "!query.is_on_ground"
            }
          ]
        }
      }
    }
  }
}