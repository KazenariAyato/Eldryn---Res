{
  "format_version": "1.19.0",
  "animation_controllers": {
    "controller.animation.cb_kitsune_beastform.move": {
      "states": {
        "crouch": {
          "animations": [
            "look_at_target",
            "crouch",
            {
              "walk": "query.modified_move_speed"
            }
          ],
          "transitions": [
            {
              "default": "!query.is_stalking && !query.is_interested"
            },
            {
              "wiggle": "query.is_interested"
            }
          ],
          "blend_transition": 0.4
        },
        "default": {
          "animations": [
            "setup",
            {
              "walk": "query.modified_move_speed"
            }
          ],
          "transitions": [
            {
              "pounce": "query.has_target && variable.attack_time >= 0.0"
            },
            {
              "sleep": "query.is_sleeping"
            },
            {
              "stuck": "query.is_stunned"
            },
            {
              "sit": "query.is_sitting"
            }
          ],
          "blend_transition": 0.1
        },
        "pounce": {
          "animations": [
            "look_at_target",
            "pounce",
            {
              "walk": "query.modified_move_speed"
            }
          ],
          "transitions": [
            {
              "default": "!query.has_target && variable.attack_time <= 0.0"
            }
          ],
          "blend_transition": 2
        },
        "sit": {
          "animations": [
            "sit"
          ],
          "transitions": [
            {
              "default": "!query.is_sitting"
            }
          ],
          "blend_transition": 0.2
        },
        "sleep": {
          "animations": [
            "sleep"
          ],
          "transitions": [
            {
              "default": "!query.is_sleeping"
            }
          ],
          "blend_transition": 0.2
        },
        "stuck": {
          "animations": [
            "stuck",
            {
              "walk": "math.cos(query.life_time * 20.0 * 53.7)"
            }
          ],
          "transitions": [
            {
              "default": "!query.is_stunned"
            }
          ],
          "blend_transition": 0.2
        },
        "wiggle": {
          "animations": [
            "look_at_target",
            "wiggle",
            {
              "walk": "query.modified_move_speed"
            }
          ],
          "transitions": [
            {
              "default": "!query.has_target && query.is_on_ground"
            },
            {
              "crouch": "query.is_on_ground && !query.is_interested && query.is_stalking"
            }
          ],
          "blend_transition": 0.2
        }
      }
    }
  }
}